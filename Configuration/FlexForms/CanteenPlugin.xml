<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <TCEforms>
                    <sheetTitle>LLL:EXT:mai_canteen/Resources/Private/Language/Default/locallang_tca.xlf:flexform.sheet.general</sheetTitle>
                </TCEforms>
                <type>array</type>
                <el>
                    <settings.pages>
                        <TCEforms>
                            <label>LLL:EXT:mai_canteen/Resources/Private/Language/Default/locallang_tca.xlf:flexform.field.pages</label>
                            <config>
                                <type>group</type>
                                <allowed>pages</allowed>
                                <size>5</size>
                                <maxitems>20</maxitems>
                                <minitems>0</minitems>
                            </config>
                        </TCEforms>
                    </settings.pages>
                    <settings.upcomingLimit>
                        <TCEforms>
                            <label>LLL:EXT:mai_canteen/Resources/Private/Language/Default/locallang_tca.xlf:flexform.field.upcomingLimit</label>
                            <config>
                                <type>number</type>
                                <default>4</default>
                                <range>
                                    <lower>1</lower>
                                    <upper>10</upper>
                                </range>
                            </config>
                        </TCEforms>
                    </settings.upcomingLimit>
                    <settings.showTemplate>
                        <TCEforms>
                            <label>LLL:EXT:mai_canteen/Resources/Private/Language/Default/locallang_tca.xlf:flexform.field.showTemplate</label>
                            <config>
                                <type>check</type>
                                <renderType>checkboxToggle</renderType>
                                <default>0</default>
                            </config>
                        </TCEforms>
                    </settings.showTemplate>
                    <settings.showWeekNavigation>
                        <TCEforms>
                            <label>LLL:EXT:mai_canteen/Resources/Private/Language/Default/locallang_tca.xlf:flexform.field.showWeekNavigation</label>
                            <config>
                                <type>check</type>
                                <renderType>checkboxToggle</renderType>
                                <default>1</default>
                            </config>
                        </TCEforms>
                    </settings.showWeekNavigation>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>
